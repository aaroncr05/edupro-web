{
  "name": "edupro-backend",
  "version": "1.0.0",
  "description": "Backend API para plataforma CRM + Ventas - Digitales Edupro",
  "main": "src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias && prisma generate && prisma migrate deploy",
    "start": "node dist/main.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "crm",
    "sales",
    "api",
    "express",
    "typescript"
  ],
  "author": "ENKI Digital",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.0.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.3.0",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "prisma": "^5.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.1.3",
    "winston": "^3.19.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.5",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "tsx": "^3.12.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
